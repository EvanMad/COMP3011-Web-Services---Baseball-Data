generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id            Int         @id @default(autoincrement())
  playerID      String      @unique
  nameFirst     String
  nameLast      String
  dateOfBirth   DateTime?   @db.Date
  dateOfDeath   DateTime?   @db.Date
  birthCountry  String?
  weight        Int
  height        Int
  bats          String?     @db.Char(1)
  throws        String?     @db.Char(1)
  battingStats  Batting[]
  pitchingStats Pitching[]
  collection    Collection? @relation(fields: [collectionId], references: [id])
  collectionId  String?

  @@map("people")
}

model Batting {
  id       Int    @id @default(autoincrement())
  playerID String
  yearID   Int
  stint    Int
  teamID   String
  lgID     String
  G        Int?
  AB       Int?
  BB       Int?
  R        Int?
  H        Int?
  HR       Int?
  RBI      Int?
  HBP      Int?
  SF       Int?
  SB       Int?
  DOUBLE   Int?
  TRIPLE   Int?
  player   Player @relation(fields: [playerID], references: [playerID])
  team     Team   @relation(fields: [yearID, teamID], references: [yearID, teamID])

  @@unique([playerID, yearID, stint])
  @@map("batting")
}

model Pitching {
  id       Int    @id @default(autoincrement())
  playerID String
  yearID   Int
  stint    Int
  teamID   String
  W        Int?
  L        Int?
  ERA      Float?
  SO       Int?
  player   Player @relation(fields: [playerID], references: [playerID])
  team     Team   @relation(fields: [yearID, teamID], references: [yearID, teamID])

  @@unique([playerID, yearID, stint])
  @@map("pitching")
}

model Team {
  id             Int        @id @default(autoincrement())
  yearID         Int
  lgID           String
  teamID         String
  franchID       String
  divID          String?
  rank           Int?       @map("Rank")
  G              Int?
  Ghome          Int?
  W              Int?
  L              Int?
  divWin         String?    @map("DivWin") @db.Char(1)
  WCWin          String?    @db.Char(1)
  LgWin          String?    @db.Char(1)
  WSWin          String?    @db.Char(1)
  R              Int?
  AB             Int?
  H              Int?
  double         Int?       @map("2B")
  triple         Int?       @map("3B")
  HR             Int?
  BB             Int?
  SO             Int?
  SB             Int?
  CS             Int?
  HBP            Int?
  SF             Int?
  RA             Int?
  ER             Int?
  ERA            Float?
  CG             Int?
  SHO            Int?
  SV             Int?
  IPouts         Int?
  HA             Int?
  HRA            Int?
  BBA            Int?
  SOA            Int?
  E              Int?
  DP             Int?
  FP             Float?
  name           String
  park           String?
  attendance     Int?
  BPF            Int?
  PPF            Int?
  teamIDBR       String?
  teamIDlahman45 String?
  teamIDretro    String?
  battingStats   Batting[]
  pitchingStats  Pitching[]

  @@unique([yearID, teamID])
  @@map("teams")
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  playerIDs   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  players     Player[]
}
