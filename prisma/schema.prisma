datasource db {
  provider = "postgresql"

}
generator client {
  provider = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

model Player {
  id           Int       @id @default(autoincrement())
  playerID     String    @unique // The Lahman unique key (e.g., "troutan01")
  nameFirst    String?
  nameLast     String?
  dateOfBirth  DateTime? @db.Date
  dateOfDeath  DateTime? @db.Date
  birthCountry String?
  weight       Int?
  height       Int?
  bats         String?   @db.Char(1)
  throws       String?   @db.Char(1)
  
  // Relations
  battingStats Batting[]
  pitchingStats Pitching[]

  @@map("people") // Lahman's modern table name is often 'People'
}

model Batting {
  id       Int    @id @default(autoincrement())
  player   Player @relation(fields: [playerID], references: [playerID])
  playerID String
  yearID   Int
  stint    Int
  teamID   String
  lgID     String
  
  // Stats
  G   Int?
  AB  Int?
  BB  Int?
  R   Int?
  H   Int?
  HR  Int?
  RBI Int?
  HBP Int?
  SF  Int?
  SB  Int?
  DOUBLE  Int?
  TRIPLE  Int?

  @@unique([playerID, yearID, stint])
  @@map("batting")
}

model Pitching {
  id       Int    @id @default(autoincrement())
  player   Player @relation(fields: [playerID], references: [playerID])
  playerID String
  yearID   Int
  stint    Int
  teamID   String
  
  W   Int?
  L   Int?
  ERA Float?
  SO  Int?

  @@unique([playerID, yearID, stint])
  @@map("pitching")
}